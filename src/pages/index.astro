---
import "../styles/global.css";
import Header from "../sections/Header.astro";
import Hero from "../sections/Hero.astro";
import Categories from "../sections/Categories.astro";
import FeaturedProducts from "../sections/FeaturedProducts.astro";
import Collections from "../sections/Collections.astro";
import WhyChooseUs from "../sections/WhyChooseUs.astro";
import Testimonials from "../sections/Testimonials.astro";
import Promotions from "../sections/Promotions.astro";
import Footer from "../sections/Footer.astro";
import ProductsCarousel from "../sections/ProductsCarousel.astro";
import SEO from "../components/SEO.astro";
import { getCurrentLanguage } from "../i18n";

// Detectar idioma desde URL
const currentLang = getCurrentLanguage(Astro);
const htmlLang = currentLang === "en" ? "en" : "es-PE";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="google-site-verification"
      content="HFY4hbNLPDFqWNVTI119L5TEeT-tIjjgs398kHZHGcI"
    />
    <SEO
      title={currentLang === "en"
        ? "RUWAQ MAQUI | Handmade Andean Textiles | Alpaca Clothing Peru"
        : "RUWAQ MAQUI | Tejidos Artesanales Andinos | Ropa de Alpaca Hecha a Mano"}
      description={currentLang === "en"
        ? "Buy authentic handmade Andean textiles at Ruwaq Maqui Peru. Alpaca shawls, sweaters, ponchos and accessories woven by rural women artisans. Traditional weaving, fair trade, natural wool. ✓ Free shipping ✓ Sustainable fashion"
        : "Compra textiles artesanales andinos auténticos en Ruwaq Maqui Perú. Chalinas de alpaca, chompas, ponchos y accesorios tejidos a mano por mujeres del campo. Tejido tradicional, comercio justo, lana natural. ✓ Envío gratis ✓ Moda sostenible"}
      canonical="/"
      keywords={currentLang === "en"
        ? "Andean textiles, alpaca clothing Peru, handmade sweaters, traditional weaving, artisan ponchos, fair trade clothing, alpaca wool shawls, sustainable fashion Peru, natural wool clothing"
        : "tejidos artesanales andinos, ropa de alpaca Perú, artesanía peruana, textiles tradicionales, ponchos artesanales, moda sostenible, chalinas de alpaca, comercio justo, lana natural, mujeres artesanas"}
      lang={currentLang}
      structuredData={{
        "@context": "https://schema.org",
        "@type": "Store",
        name: "Ruwaq Maqui",
        description:
          "Tienda de textiles artesanales andinos tejidos a mano por mujeres del campo con lana de alpaca y oveja",
        url: "https://oro-inca-joyeria.vercel.app/",
        logo: "https://oro-inca-joyeria.vercel.app/assets/img/logo.png",
        image: "https://oro-inca-joyeria.vercel.app/assets/img/og-image.jpg",
        priceRange: "$$",
        address: {
          "@type": "PostalAddress",
          addressCountry: "PE",
          addressLocality: "Lima",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: "-12.046374",
          longitude: "-77.042793",
        },
        areaServed: {
          "@type": "Country",
          name: "Perú",
        },
        currenciesAccepted: "PEN",
        paymentAccepted: "Tarjeta de crédito, débito, transferencia bancaria",
        openingHours: "Mo-Sa 09:00-20:00",
        telephone: "+51-XXX-XXX-XXX",
      }}
    />

    <!-- Preconnect para mejorar velocidad -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Favicon optimizado -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph mejorado -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="RUWAQ MAQUI | Tejidos Artesanales Andinos | Ropa de Alpaca"
    />
    <meta
      property="og:description"
      content="Textiles artesanales andinos tejidos a mano con lana de alpaca y oveja. Chalinas, chompas, ponchos y accesorios hechos por mujeres del campo. Comercio justo y tradición ancestral."
    />
    <meta property="og:url" content="https://oro-inca-joyeria.vercel.app/" />
    <meta
      property="og:image"
      content="https://oro-inca-joyeria.vercel.app/assets/img/og-image.jpg"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Ruwaq Maqui - Textiles Artesanales Andinos"
    />
    <meta property="og:site_name" content="Ruwaq Maqui" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter Cards mejorado -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="RUWAQ MAQUI | Tejidos Artesanales Andinos de Perú"
    />
    <meta
      name="twitter:description"
      content="Textiles artesanales andinos tejidos a mano. Ropa de alpaca, comercio justo, mujeres artesanas."
    />
    <meta
      name="twitter:image"
      content="https://oro-inca-joyeria.vercel.app/assets/img/og-image.jpg"
    />
    <meta
      name="twitter:image:alt"
      content="Ruwaq Maqui - Colección de textiles artesanales"
    />
    <meta name="twitter:site" content="@ruwaqmaqui" />
    <meta name="twitter:creator" content="@ruwaqmaqui" />

    <!-- Schema.org para SEO local -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Store",
        "name": "Ruwaq Maqui",
        "description": "Tienda de textiles artesanales andinos tejidos a mano por mujeres del campo con lana de alpaca y oveja",
        "url": "https://oro-inca-joyeria.vercel.app/",
        "logo": "https://oro-inca-joyeria.vercel.app/assets/img/logo.png",
        "image": "https://oro-inca-joyeria.vercel.app/assets/img/og-image.jpg",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "PE",
          "addressLocality": "Lima"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "-12.046374",
          "longitude": "-77.042793"
        },
        "areaServed": {
          "@type": "Country",
          "name": "Perú"
        },
        "currenciesAccepted": "PEN",
        "paymentAccepted": "Tarjeta de crédito, débito, transferencia bancaria",
        "openingHours": "Mo-Sa 09:00-20:00",
        "telephone": "+51-XXX-XXX-XXX"
      }
    </script>

    <!-- Schema.org para organización -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Ruwaq Maqui",
        "url": "https://oro-inca-joyeria.vercel.app/",
        "logo": "https://oro-inca-joyeria.vercel.app/assets/img/logo.png",
        "sameAs": [
          "https://www.facebook.com/ruwaqmaqui",
          "https://www.instagram.com/ruwaqmaqui",
          "https://twitter.com/ruwaqmaqui"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+51-XXX-XXX-XXX",
          "contactType": "Customer Service",
          "areaServed": "PE",
          "availableLanguage": ["Spanish", "English"]
        }
      }
    </script>

    <!-- Breadcrumb Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Inicio",
            "item": "https://oro-inca-joyeria.vercel.app/"
          }
        ]
      }
    </script>
  </head>
  <body>
    <Header />
    <main>
      <Hero lang={currentLang} />
      <Categories lang={currentLang} />
      <FeaturedProducts lang={currentLang} />
      <Collections lang={currentLang} />
      <WhyChooseUs lang={currentLang} />
      <Testimonials lang={currentLang} />
      <Promotions lang={currentLang} />
    </main>
    <Footer />
  </body>
</html>
